  patronFirstName: &lt;&lt;borrowers.firstname&gt;&gt;
  patronLastName: &lt;&lt;borrowers.surname&gt;&gt;
  phone: &lt;&lt;borrowers.smsalertnumber&gt;&gt;
  email: &lt;&lt;borrowers.email&gt;&gt;
  branch: &lt;&lt;branches.branchcode&gt;&gt;
